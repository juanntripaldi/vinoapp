# Copiá este archivo como .env y completá los valores

# Clave API de Anthropic (para el Consultor IA)
# Obtenela en: https://console.anthropic.com/
ANTHROPIC_API_KEY=tu_clave_aqui

# Conexión a MongoDB Atlas
# Formato: mongodb+srv://usuario:contraseña@cluster.mongodb.net/vinoapp?retryWrites=true&w=majority
MONGODB_URI=tu_uri_aqui

# Puerto del servidor (default: 3000)
PORT=3000
